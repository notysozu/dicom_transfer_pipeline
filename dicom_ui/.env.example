# dicom_ui profile
NODE_ENV=development
LOG_LEVEL=info

# Backend HTTPS server
UI_BACKEND_HOST=0.0.0.0
UI_BACKEND_PORT=9443
TLS_CERT_PATH=./backend/certificates/server.pem
TLS_KEY_PATH=./backend/certificates/key.pem
TLS_CA_PATH=./backend/certificates/ca.pem
TLS_REJECT_UNAUTHORIZED=true

# JWT
JWT_SECRET=replace-with-secure-random-secret
JWT_EXPIRES_IN=1h
BCRYPT_SALT_ROUNDS=12

# MongoDB
MONGODB_URI=mongodb+srv://admin:5TFeznFwDcpEDwj@cluster0.v2upcza.mongodb.net/?appName=Cluster0
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# Guardian API
GUARDIAN_BASE_URL=https://127.0.0.1:8443
GUARDIAN_API_TIMEOUT_MS=10000
GUARDIAN_TLS_CA_PATH=./backend/certificates/guardian-ca.pem

# Frontend
VITE_API_BASE_URL=https://127.0.0.1:9443/api

# Super Admin seeding (Step 18)
SEED_SUPER_ADMIN_USERNAME=superadmin
SEED_SUPER_ADMIN_EMAIL=superadmin@hospital.local
SEED_SUPER_ADMIN_PASSWORD=ChangeMeNow!2026
SEED_SUPER_ADMIN_FIRST_NAME=Super
SEED_SUPER_ADMIN_LAST_NAME=Admin
SEED_SUPER_ADMIN_DEPARTMENT=Platform Administration
