# Installer controls
REPO_URL=https://github.com/notysozu/dicom_transfer_pipeline.git  # Remote used by install scripts
INSTALL_DIR=~/dicom_transfer_pipeline  # Target checkout directory
START_TARGET=guardian  # guardian | ui-backend | ui-frontend

# dicom_guardian runtime profile
ENVIRONMENT=development  # Runtime environment label
API_HOST=0.0.0.0  # FastAPI bind host
API_PORT=8443  # FastAPI bind port
DICOM_AE_TITLE=DICOM_GUARDIAN  # Local DICOM AE title
DICOM_HOST=0.0.0.0  # DICOM listener host
DICOM_PORT=11112  # DICOM listener port
PACS_AE_TITLE=PACS_SERVER  # Remote PACS AE title
PACS_HOST=127.0.0.1  # Remote PACS host
PACS_PORT=11113  # Remote PACS port
DATABASE_PATH=./dicom_guardian.db  # SQLite file path
TLS_CERT_FILE=./certificates/server.pem  # Guardian TLS certificate path
TLS_KEY_FILE=./certificates/key.pem  # Guardian TLS private key path
TLS_CA_FILE=./certificates/ca.pem  # Guardian trusted CA path
LOG_LEVEL=INFO  # Python service log level

# dicom_ui backend profile
NODE_ENV=development  # Backend runtime mode
UI_BACKEND_HOST=0.0.0.0  # Express bind host
UI_BACKEND_PORT=9443  # Express bind port
TLS_CERT_PATH=./backend/certificates/server.pem  # UI TLS certificate path
TLS_KEY_PATH=./backend/certificates/key.pem  # UI TLS private key path
TLS_CA_PATH=./backend/certificates/ca.pem  # UI trusted CA path
TLS_REJECT_UNAUTHORIZED=true  # Whether outbound TLS rejects untrusted certs
JWT_SECRET=replace-with-long-random-secret  # JWT signing secret
JWT_EXPIRES_IN=1h  # Access token lifetime
BCRYPT_SALT_ROUNDS=12  # Password hashing cost
MONGODB_URI=mongodb://localhost:27017/dicom_ui  # MongoDB connection string
MONGODB_MAX_POOL_SIZE=10  # MongoDB max pool size
MONGODB_MIN_POOL_SIZE=2  # MongoDB min pool size
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000  # MongoDB server selection timeout
GUARDIAN_BASE_URL=https://127.0.0.1:8443  # Guardian API base URL
GUARDIAN_API_TIMEOUT_MS=10000  # Guardian HTTP timeout in milliseconds
GUARDIAN_TLS_CA_PATH=./backend/certificates/guardian-ca.pem  # Guardian CA file for UI backend
VITE_API_BASE_URL=https://127.0.0.1:9443/api  # Frontend API base URL
SEED_SUPER_ADMIN_USERNAME=superadmin  # Seeded admin username
SEED_SUPER_ADMIN_EMAIL=superadmin@example.local  # Seeded admin email
SEED_SUPER_ADMIN_PASSWORD=replace-with-strong-password  # Seeded admin password
SEED_SUPER_ADMIN_FIRST_NAME=Super  # Seeded admin first name
SEED_SUPER_ADMIN_LAST_NAME=Admin  # Seeded admin last name
SEED_SUPER_ADMIN_DEPARTMENT=Platform Administration  # Seeded admin department
