# dicom_guardian runtime profile
ENVIRONMENT=development

# API
API_HOST=0.0.0.0
API_PORT=8443

# DICOM networking (to be wired in later steps)
DICOM_AE_TITLE=DICOM_GUARDIAN
DICOM_HOST=0.0.0.0
DICOM_PORT=11112

# PACS endpoint (to be wired in later steps)
PACS_AE_TITLE=PACS_SERVER
PACS_HOST=127.0.0.1
PACS_PORT=11113

# Database
DATABASE_PATH=./dicom_guardian.db

# TLS paths
TLS_CERT_FILE=./certificates/server.pem
TLS_KEY_FILE=./certificates/key.pem
TLS_CA_FILE=./certificates/ca.pem

# Logging
LOG_LEVEL=INFO
